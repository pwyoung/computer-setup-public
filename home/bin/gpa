#!/bin/bash

# 1. Identify current branch
BRANCH=$(git rev-parse --abbrev-ref HEAD)

# 2. Display ONLY the push remotes (no fetch URLs)
echo "--- Target Push Remotes ---"
git remote -v | grep '(push)' | awk '{print $1 " \t " $2}'
echo "---------------------------"

# 3. Push to each remote
REMOTES=$(git remote)
for REMOTE in $REMOTES; do
    echo -e "\nPushing $BRANCH to $REMOTE..."
    git push "$REMOTE" "$BRANCH"
done

echo -e "\nAll pushes complete."
