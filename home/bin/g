#!/bin/bash

# Quickly search source code
# Examples
# - g "foo"
# - g -x "bar" "foo"

run_grep() {
    local exclude_pattern=""
    local args=()

    # Simple argument parser
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -x)
                exclude_pattern="$2"
                shift 2
                ;;
            *)
                args+=("$1")
                shift
                ;;
        esac
    done

    if command -v rg &>/dev/null; then
        # ripgrep uses -g for glob patterns.
        # *{pattern}* ensures it matches anywhere in the path.
        local rg_exclude=()
        if [[ -n "$exclude_pattern" ]]; then
            rg_exclude=(-g "!*${exclude_pattern}*")
        fi

        rg -uu \
           -g '!{.venv,.git,.terragrunt-cache,.claude}' \
           -g '!{tmp,ai-log,ai-log-summary}' \
           -g '!*.{pdf,jpg,jpeg,png,zip,tar,gz,exe,bin,mp4,mp3}' \
           "${rg_exclude[@]}" \
           --color=always "${args[@]}"
    else
        # Standard grep syntax
        local grep_exclude=()
        if [[ -n "$exclude_pattern" ]]; then
            grep_exclude=(--exclude-dir="*${exclude_pattern}*" --exclude="*${exclude_pattern}*")
        fi

        grep -r \
             --exclude-dir=.venv \
             --exclude-dir=.git \
             --exclude-dir=.terragrunt-cache \
             --exclude-dir=.claude \
             --exclude-dir=tmp \
             --exclude-dir=ai-log \
             --exclude-dir=ai-log-summary \
             --exclude='*.{pdf,jpg,jpeg,png,zip,tar,gz,exe,bin,mp4,mp3}' \
             "${grep_exclude[@]}" \
             --color=always "${args[@]}"
    fi
}

run_grep "$@"
